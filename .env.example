DATABASE_URL=
PUBLIC_SITE_URL=
APP_ENV=development
AGORA_HTTP_PORT=8080
DB_ECHO=false
JWT_SECRET=
GITHUB_TOKEN=
GITHUB_REPO=
CORS_ORIGIN=
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Auto-deploy: set to false to skip git pull + docker compose rebuild after merge
DEPLOY_ENABLED=false
GOVERNANCE_POLL_SECONDS=60
AUTH_LOGIN_ATTEMPTS=10
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_REGISTER_ATTEMPTS=30
AUTH_REGISTER_WINDOW_SECONDS=3600
AUTH_SESSION_MAX_AGE_SECONDS=2592000
AUTH_MAX_SESSIONS_PER_USER=3
# Development/test only. Do not reuse this key in production.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Production uses the provider-neutral OpenAI-compatible values below. Values saved in /admin
# take precedence; these variables remain the no-database fallback. When
# production AI is enabled, DEEPSEEK_API_KEY is rejected at startup.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
# AI endpoints remain unavailable until explicitly enabled with a non-empty key.
AI_FEATURES_ENABLED=false
AI_HTTP_TIMEOUT_SECONDS=20
AI_TEMPERATURE=0
AI_RESPONSE_FORMAT_ENABLED=true
# Leave empty for generic OpenAI-compatible providers. DeepSeek also accepts
# disabled or enabled when an explicit reasoning mode is wanted.
AI_THINKING_MODE=
# Preferred trusted in-network semantic classifier. It must
# accept {"texts":[...]} and return {"statuses":["non_political", ...]}.
AI_POLITICAL_CLASSIFIER_URL=
AI_POLITICAL_CLASSIFIER_TIMEOUT_SECONDS=3
# Development/test may reuse the configured provider for semantic moderation.
# Keep this false in production unless external moderation is an explicit choice.
AI_MODERATION_PROVIDER_FALLBACK_ENABLED=false
# Change the policy version to invalidate cached verdicts after policy updates.
AI_MODERATION_POLICY_VERSION=semantic-politics-v1
# Change when the classifier implementation or calibration changes.
AI_POLITICAL_CLASSIFIER_VERSION=semantic-classifier-v1
AI_MODERATION_CACHE_TTL_SECONDS=604800
AI_MODERATION_RATE_LIMIT_GLOBAL_QPS=12
AI_MODERATION_RATE_LIMIT_DAILY_GLOBAL_REQUESTS=10000
AI_MODERATION_MAX_CONCURRENT_REQUESTS=8
AI_MAX_INPUT_CHARS=12000
AI_RATE_LIMIT_REQUESTS=20
AI_RATE_LIMIT_IP_REQUESTS=60
AI_RATE_LIMIT_GLOBAL_REQUESTS=200
AI_RATE_LIMIT_GLOBAL_QPS=8
AI_RATE_LIMIT_DAILY_GLOBAL_REQUESTS=2000
AI_RATE_LIMIT_WINDOW_SECONDS=60
# Five-minute collision guard; published polls are the durable duplicate source.
AI_POLL_RESERVATION_TTL_SECONDS=300
AI_TRANSLATION_CACHE_TTL_SECONDS=604800
AI_MAX_CONCURRENT_REQUESTS=8
