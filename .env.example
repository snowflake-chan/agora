DATABASE_URL=
APP_ENV=development
DB_ECHO=false
JWT_SECRET=
GITHUB_TOKEN=
GITHUB_REPO=
CORS_ORIGIN=
# Auto-deploy: set to false to skip git pull + docker compose rebuild after merge
DEPLOY_ENABLED=false
GOVERNANCE_POLL_SECONDS=60
AUTH_LOGIN_ATTEMPTS=10
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_REGISTER_ATTEMPTS=30
AUTH_REGISTER_WINDOW_SECONDS=3600
# Development/test only. Do not reuse this key in production.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Production uses the provider-neutral OpenAI-compatible values below. When
# production AI is enabled, DEEPSEEK_API_KEY is rejected at startup.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
# AI endpoints remain unavailable until explicitly enabled with a non-empty key.
AI_FEATURES_ENABLED=false
AI_HTTP_TIMEOUT_SECONDS=20
AI_MAX_INPUT_CHARS=12000
AI_RATE_LIMIT_REQUESTS=20
AI_RATE_LIMIT_IP_REQUESTS=60
AI_RATE_LIMIT_GLOBAL_REQUESTS=200
AI_RATE_LIMIT_DAILY_GLOBAL_REQUESTS=2000
AI_RATE_LIMIT_WINDOW_SECONDS=60
# Five-minute collision guard; published polls are the durable duplicate source.
AI_POLL_RESERVATION_TTL_SECONDS=300
