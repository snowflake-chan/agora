---
import PillActions from "./PillActions.svelte";
import NotificationBell from "./NotificationBell.svelte";
---

<!-- Top header -->
<header class="appbar-top">
  <div class="flex h-12 items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2">
      <img src="/favicon.svg" alt="" width="22" height="22" class="size-[22px]" />
      <span class="text-lg font-bold tracking-tight" style="color: var(--vercel-text);">Agora</span>
    </a>
    <NotificationBell client:load />
  </div>
</header>

<!-- Floating pill navigation -->
<nav class="pill-bar">
  <PillActions client:load />
</nav>

<style is:global>
  .appbar-top {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    background: rgba(12, 12, 14, 0.35);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
  }

  /* Push main content below the fixed header */
  body {
    padding-top: 3rem;
  }

  .pill-bar {
    position: fixed;
    bottom: max(8px, env(safe-area-inset-bottom));
    left: 50%;
    z-index: 60;
    transform: translateX(-50%);
    background: rgba(18, 18, 22, 0.45);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 9999px;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: 0 2px 20px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.04);
  }

  .pill-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    color: #fff;
    transition: color 0.18s ease, background 0.18s ease, transform 0.18s ease;
    cursor: pointer;
    text-decoration: none;
    background: transparent;
    border: 0;
    font-family: inherit;
  }

  .pill-item:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
  }

  .pill-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(2px);
    padding: 0.25rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--vercel-text);
    background: rgba(30, 30, 30, 0.95);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: all 0.15s ease;
  }

  .pill-item:hover .pill-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .pill-item:focus-visible {
    outline: 2px solid rgba(255,255,255,.85);
    outline-offset: 2px;
  }

  @media (max-width: 40rem) {
    body {
      padding-bottom: calc(4.5rem + env(safe-area-inset-bottom));
    }

    .pill-bar {
      right: .5rem;
      bottom: max(.5rem, env(safe-area-inset-bottom));
      left: .5rem;
      transform: none;
      border-radius: 1rem;
      background: rgba(18,18,22,.82);
    }
  }
</style>
