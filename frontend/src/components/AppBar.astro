---
import PillActions from "./PillActions.svelte";
import BanGate from "./BanGate.svelte";
import NotificationBell from "./NotificationBell.svelte";
import SettingsButton from "./SettingsButton.svelte";
import AboutButton from "./AboutButton.svelte";
---

<!-- Top header -->
<header class="appbar-top">
  <div class="flex h-12 items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2">
      <img src="/favicon.svg" alt="" width="22" height="22" class="size-[22px]" />
      <span class="text-lg font-bold tracking-tight" style="color: var(--vercel-text);">Agora</span>
    </a>
    <div class="flex items-center gap-1">
      <AboutButton client:load />
      <SettingsButton client:load />
      <NotificationBell client:load />
    </div>
  </div>
</header>

<!-- Floating pill navigation -->
<nav class="pill-bar">
  <PillActions client:load />
</nav>

<BanGate client:load />

<style is:global>
  .appbar-top {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    border-bottom: 1px solid var(--vercel-border);
    background: color-mix(in srgb, var(--vercel-bg) 72%, transparent);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
  }

  /* Push main content below the fixed header */
  body {
    padding-top: 3rem;
  }

  .pill-bar {
    position: fixed;
    bottom: max(8px, env(safe-area-inset-bottom));
    left: 50%;
    z-index: var(--z-nav);
    transform: translateX(-50%);
    background: color-mix(in srgb, var(--vercel-card) 78%, transparent);
    border: 1px solid var(--vercel-border);
    border-radius: 9999px;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: 0 2px 20px color-mix(in srgb, var(--vercel-bg) 35%, transparent), 0 0 0 1px var(--vercel-border);
  }

  .pill-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    color: var(--vercel-text);
    transition: color 0.15s ease, background 0.15s ease, transform 0.15s ease;
    cursor: pointer;
    text-decoration: none;
    background: transparent;
    border: 0;
    font-family: inherit;
  }

  .pill-item:hover {
    color: var(--vercel-text);
    background: var(--vercel-hover-strong);
  }

  .pill-item:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--vercel-text) 88%, transparent);
    outline-offset: 2px;
  }

  .pill-item:active {
    transform: scale(0.94);
  }

  .pill-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(2px);
    padding: 0.25rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--vercel-text);
    background: var(--vercel-surface-raised);
    border: 1px solid var(--vercel-border);
    border-radius: 4px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .pill-item:hover .pill-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 40rem) {
    body {
      padding-bottom: calc(4.5rem + env(safe-area-inset-bottom));
    }

    .pill-bar {
      right: 0.5rem;
      bottom: max(0.5rem, env(safe-area-inset-bottom));
      left: 0.5rem;
      transform: none;
      border-radius: 1rem;
      background: color-mix(in srgb, var(--vercel-card) 82%, transparent);
    }
  }
</style>
