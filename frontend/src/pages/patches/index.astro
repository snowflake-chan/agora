---
// Redirect to home page; the MainView component reads localStorage to
// pre-select the patches view so the transition is seamless.
---

<html lang="zh-CN">
  <head>
    <meta http-equiv="refresh" content="0; url=/" />
    <script is:inline>
      try { localStorage.setItem("agora:initView", "patches"); } catch (e) {}
    </script>
  </head>
  <body>
    <p style="color:#888;font-family:sans-serif;padding:2rem">正在跳转到首页…</p>
  </body>
</html>
