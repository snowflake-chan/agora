---
import Layout from "../../layouts/Layout.astro";
import AppBar from "../../components/AppBar.astro";
import PostForm from "../../components/posts/PostForm.svelte";
import LocalizedText from "../../components/LocalizedText.svelte";
---

<Layout title="New post · Agora" titleKey="post.new">
  <AppBar />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <div class="empty-state">
      <p class="text-sm" style="color: var(--vercel-text-tertiary);">
        <LocalizedText messageKey="editor.loading" client:load />
      </p>
    </div>
  </main>
  <PostForm client:load onClose={() => window.history.back()} />
</Layout>
