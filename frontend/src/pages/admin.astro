---
import Layout from "../layouts/Layout.astro";
import AppBar from "../components/AppBar.astro";
import AdminDashboard from "../components/admin/AdminDashboard.svelte";
---

<Layout title="Administration · Agora" titleKey="admin.title">
  <AppBar />
  <main class="admin-page mx-auto max-w-5xl px-4 py-8">
    <AdminDashboard client:load />
  </main>
</Layout>

<style>
  @media (max-width: 40rem) {
    .admin-page {
      box-sizing: border-box;
      height: calc(100dvh - 3rem - 4.75rem - env(safe-area-inset-bottom));
      overflow-y: auto;
      overscroll-behavior: contain;
      padding-top: 1.75rem;
      padding-bottom: 1.25rem;
      scrollbar-gutter: stable;
    }
  }
</style>
