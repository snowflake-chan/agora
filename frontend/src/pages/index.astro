---
import Layout from "../layouts/Layout.astro";
import AppBar from "../components/AppBar.svelte";
import FeedList from "../components/FeedList.svelte";
---

<Layout>
  <AppBar client:load />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-xl font-bold text-surface-900-100">最新动态</h1>
      <div class="flex gap-2">
        <a href="/patches/new" class="btn preset-filled-warning-500 text-sm">发起变更</a>
        <a href="/posts/new" class="btn preset-filled-primary-500 text-sm">发帖</a>
      </div>
    </div>
    <div class="rounded-xl border border-surface-200-800/50 bg-surface shadow-sm overflow-hidden">
      <FeedList client:load />
    </div>
  </main>
</Layout>
